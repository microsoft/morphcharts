{
  "title": "US Tornados",
  "description": "US Tornados Unit Stack by Month, Strength",

  "signals": [
    { "name": "stackWidth", "value": 10},
    { "name": "stackDepth", "value": 10},
    { "name": "width", "update": "12*(stackWidth+1)"},
    { "name": "depth", "update": "6*(stackDepth+1)"}
  ],

  "camera": {
    "altitude": 45,
    "distance": 2,
    "target": [0, 0, -0.3]
  },

  "ambient": "black",
  "background": "black",
  
  "lights": [
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 30, "azimuth":   0, "brightness": 10, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth":  90, "brightness":  2, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth": -90, "brightness":  2, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth": 180, "brightness":  2, "color": "oldlace"}
  ],

  "data": [
    {
      "name": "months",
      "values": [
        {"id":  1, "name": "Jan"}, {"id":  2, "name": "Feb"}, {"id":  3, "name": "Mar"},
        {"id":  4, "name": "Apr"}, {"id":  5, "name": "May"}, {"id":  6, "name": "Jun"},
        {"id":  7, "name": "Jul"}, {"id":  8, "name": "Aug"}, {"id":  9, "name": "Sep"},
        {"id": 10, "name": "Oct"}, {"id": 11, "name": "Nov"}, {"id": 12, "name": "Dec"}
      ]
    },
    {
      "name": "strengths",
      "transform": [
        {"type": "sequence", "start": 0, "stop": 6}
      ]
    },
    {
      "name": "table",
      "url": "data/ustornados_1950-2024.csv",
      "transform": [
        {"type": "formula", "expr": "0.5+random()*0.25", "as": "fuzz"},
        {"type": "lookup", "from": "months", "key": "id", "fields": ["mo"], "values": ["name"], "as": ["monthname"]}
      ]
    },
    {
      "name": "unitstack",
      "source": "table",
      "transform": [
        {
          "type": "unitstack",
          "groupby": ["mo", "mag"],
          "x": {"signal": "stackWidth"}, 
          "width": {"signal": "stackWidth"}, 
          "z": {"signal": "stackDepth"},
          "depth": {"signal": "stackDepth"}
        }
      ]
    }
  ],

  "scales": [
    {
      "name": "month",
      "type": "band",
      "domain": {"data": "months", "field": "name", "sort": {"field": "id", "op": "max"}},
      "range": {"step": {"signal": "stackWidth+1"}}
    },
    {
      "name": "strength",
      "type": "band",
      "domain": {"data": "strengths", "field": "data"},
      "range": "depth",
      "reverse": false
    },
    {
      "name": "fill",
      "type": "linear",
      "domain": {"data": "table", "field": "mag"},
      "range": {"scheme": "yelloworangebrown"},
      "zero": false,
      "reverse": true
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "month",
      "labelBaseline": "top",
      "labelFontSize": 3,
      "labelOffsetY": -2,
      "labelOffsetZ": 2,
      "labelFontWeight": 400,
      "labelAngleX": 90,
      "labelColor": "black",
      "bandGridPosition": 1,
      "bandLabelPosition": 0.5,
      "title": "Month",
      "titleAngleX": 90,
      "titleBaseline": "top",
      "titleOffsetZ": 6,
      "titleOffsetY": -2,
      "titleFontSize": 3,
      "titleFontWeight": 400,
      "titleColor": "black",
      "gridZ": true,
      "gridWidth": 0.05,
      "gridColor": "black",
      "domainWidth": 0.05,
      "domainColor": "black"
    },
    {
      "orient": "left",
      "orientZ": "bottom",
      "scale": "strength",
      "labelAlign": "right",
      "labelOffsetX": -2,
      "labelOffsetY": -2,
      "labelFontSize": 3,
      "labelFontWeight": 400,
      "labelAngleX": 90,
      "labelColor": "black",
      "bandGridPosition": 1,
      "bandLabelPosition": 0.5,
      "title": "Strengh",
      "titleAngleX": 90,
      "titleAngleZ": -90,
      "titleBaseline": "bottom",
      "titleOffsetX": -6,
      "titleOffsetY": -2,
      "titleFontSize": 3,
      "titleFontWeight": 400,
      "titleColor": "black",
      "grid": true,
      "gridWidth": 0.05,
      "gridColor": "black",
      "domainWidth": 0.05,
      "domainColor": "black"
    }
  ],

  "marks": [
    {
      "type": "rect",
      "geometry": "xzrect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "yc": {"value": -0.01},
          "width": {"signal": "width"},
          "depth": {"signal": "depth"},
          "fill": {
            "checker": {
              "color1": { "value": "gainsboro" },
              "color2": { "value": "whitesmoke" }
            },
            "texScale": {
              "x": {"value": 6},
              "z": {"value": 3}
            }
          }
        }
      }
    },
    {
      "type": "rect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "y": {"value": -0.02},
          "y2": {"value": -2},
          "width": {"signal": "width"},
          "depth": {"signal": "depth"},
          "fill": {"value": "white"}
        }
      }
    },
    {
      "type": "rect",
      "geometry": "xzrect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "yc": {"value": -2.01},
          "width": {"signal": "width*4"},
          "depth": {"signal": "depth*8"},
          "fill": {"value": "darkgray"}
        }
      }
    },
    {
      "type": "rect",
      "geometry": "box",
      "material": "metal",
      "from": {"data": "unitstack"},
      "encode": {
        "enter": {
          "x": {"field": "x0", "offset": {"scale": "month", "field": "monthname"}},
          "x2": {"field": "x1", "offset": {"scale": "month", "field": "monthname"}},
          "y": {"field": "y0"},
          "y2": {"field": "y1"},
          "z": {"field": "z0", "offset": {"scale": "strength", "field": "mag"}},
          "z2": {"field": "z1", "offset": {"scale": "strength", "field": "mag"}},
          "rounding": {"value": 0.1},
          "fill": {"scale": "fill", "field": "mag"},
          "fuzz": {"field": "fuzz"}
        }
      }
    }
  ]
}