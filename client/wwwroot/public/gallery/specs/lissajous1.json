{
  "title": "Lissajous Curve",
  "description": "A Lissajous curve generator",

  "width": 640,
  "height": 360,
  "depth": 640,

  "camera": {
    "distance": 2.5,
    "altitude": 30,
    "azimuth": 60,
    "position": [0, 0, 0],
    "target": [0, -0.1, 0]
  },

  "ambient": "black",
  "background": "black",

  "lights": [
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth": 180, "brightness": 8, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth": -90, "brightness": 8, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth":   0, "brightness": 2, "color": "oldlace"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth":  90, "brightness": 2, "color": "oldlace"}
  ],

  "signals": [
    {"name": "rows", "value": 2000},
    {"name": "a", "value": 19},
    {"name": "b", "value": 23},
    {"name": "c", "value": 4},
    {"name": "strokeWidth", "value": 8}
  ],

  "data": [
    {
      "name": "table", 
      "transform": [
        {"type": "sequence", "start": 0, "stop": {"signal": "rows+1"}, "step": 1, "as": "id"},
        {"type": "formula", "as": "t", "expr": "2*PI*datum.id/(rows+1)"},
        {"type": "formula", "as": "x", "expr": "sin(a*datum.t)"},
        {"type": "formula", "as": "y", "expr": "sin(b*datum.t)"},
        {"type": "formula", "as": "z", "expr": "sin(c*datum.t)"}
      ]
    }
  ], 

  "scales": [
    {
      "name": "x",
      "type": "linear",
      "domain": {"data": "table", "field": "x"},
      "range": "width"
    },
    {
      "name": "y",
      "type": "linear",
      "domain": {"data": "table", "field": "y"},
      "range": "height"
    },
    {
      "name": "z",
      "type": "linear",
      "domain": {"data": "table", "field": "z"},
      "range": "depth"
    },
    {
      "name": "fill",
      "type": "linear",
      "domain": {"data": "table", "field": "t"},
      "range": {"scheme": "oranges"}
    }
  ],

  "marks": [
    {
      "type": "rect",
      "geometry": "xzrect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "yc": {"signal": "-strokeWidth/2-0.01"},
          "width": {"signal": "width*8"},
          "depth": {"signal": "depth*8"},
          "fill": {"value": "darkgray"}
        }
      }
    },
    {
      "type": "line",
      "geometry": "cylinder",
      "material": "metal",
      "from": {"data": "table"},
      "encode": {
        "enter": {
          "x": {"scale": "x", "field": "x"},
          "y": {"scale": "y", "field": "y"},
          "z": {"scale": "z", "field": "z"},
          "fuzz": {"value": 0.2},
          "strokeWidth": {"signal": "strokeWidth"},
          "stroke": {"value": "DarkGoldenrod"},
          "_stroke": {"scale": "fill", "field": "t"}
        }
      }
    }
  ]
}