{
  "title": "US Tornados",
  "description": "US Tornados Unit Stack by Hour, Strength",

  "signals": [
    { "name": "stackWidth", "value": 6},
    { "name": "stackDepth", "value": 6},
    { "name": "width", "update": "24*(stackWidth+1)"},
    { "name": "depth", "update": "6*(stackDepth+1)"}
  ],

  "camera": {
    "altitude": 45,
    "distance": 1.8,
    "target": [0, 0, -0.5]
  },

  "ambient": "black",
  "background": "black",
  
  "lights": [
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth":  -45, "brightness": 8, "color": "lightgoldenrodyellow"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth":   45, "brightness": 2, "color": "lightgoldenrodyellow"},
    {"type": "rect", "size": 0.5, "distance": 1, "altitude": 45, "azimuth": -135, "brightness": 2, "color": "lightgoldenrodyellow"}
  ],

  "data": [
    {
      "name": "hours",
      "transform": [
        {"type": "sequence", "start": 0, "stop": 24, "as": "hour"}
      ]
    },
    {
      "name": "strengths",
      "transform": [
        {"type": "sequence", "start": 0, "stop": 6}
      ]
    },
    {
      "name": "table",
      "url": "data/ustornados_1950-2024.csv",
      "transform": [
        {"type": "formula", "expr": "0.5+random()*0.25", "as": "fuzz"},
        {"type": "formula", "expr": "substring(datum.time,0,2)", "as": "hour"}
      ]
    },
    {
      "name": "unitstack",
      "source": "table",
      "transform": [
        {
          "type": "unitstack",
          "groupby": ["hour", "mag"],
          "x": {"signal": "stackWidth"}, 
          "width": {"signal": "stackWidth"}, 
          "z": {"signal": "stackDepth"},
          "depth": {"signal": "stackDepth"}
        }
      ]
    }
  ],

  "scales": [
    {
      "name": "hour",
      "type": "band",
      "domain": {"data": "hours", "field": "hour"},
      "range": {"step": {"signal": "stackWidth+1"}}
    },
    {
      "name": "strength",
      "type": "band",
      "domain": {"data": "strengths", "field": "data"},
      "range": "depth",
      "reverse": false
    },
    {
      "name": "fill",
      "type": "linear",
      "domain": {"data": "table", "field": "mag"},
      "range": {"scheme": "yelloworangebrown"},
      "zero": false,
      "reverse": true
    }
  ],

  "axes": [
    {
      "orient": "bottom",
      "scale": "hour",
      "labelBaseline": "top",
      "labelFontSize": 3,
      "labelOffsetY": -2,
      "labelOffsetZ": 2,
      "labelFontWeight": 400,
      "labelAngleX": 90,
      "labelColor": "black",
      "bandGridPosition": 1,
      "bandLabelPosition": 0.5,
      "title": "Hour",
      "titleAngleX": 90,
      "titleBaseline": "top",
      "titleOffsetZ": 6,
      "titleOffsetY": -2,
      "titleFontSize": 3,
      "titleFontWeight": 400,
      "titleColor": "black",
      "gridZ": true,
      "gridWidth": 0.05,
      "gridColor": "black",
      "domainWidth": 0.05,
      "domainColor": "black"
    },
    {
      "orient": "left",
      "orientZ": "bottom",
      "scale": "strength",
      "labelAlign": "right",
      "labelOffsetX": -2,
      "labelOffsetY": -2,
      "labelFontSize": 3,
      "labelFontWeight": 400,
      "labelAngleX": 90,
      "labelColor": "black",
      "bandGridPosition": 1,
      "bandLabelPosition": 0.5,
      "title": "Strengh",
      "titleAngleX": 90,
      "titleAngleZ": -90,
      "titleBaseline": "bottom",
      "titleOffsetX": -6,
      "titleOffsetY": -2,
      "titleFontSize": 3,
      "titleFontWeight": 400,
      "titleColor": "black",
      "grid": true,
      "gridWidth": 0.05,
      "gridColor": "black",
      "domainWidth": 0.05,
      "domainColor": "black"
    }
  ],

  "marks": [
    {
      "type": "rect",
      "geometry": "xzrect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "yc": {"value": -0.01},
          "width": {"signal": "width"},
          "depth": {"signal": "depth"},
          "fill": {
            "checker": {
              "color1": { "value": "gainsboro" },
              "color2": { "value": "whitesmoke" }
            },
            "texScale": {
              "x": {"value": 12},
              "z": {"value": 3}
            }
          }
        }
      }
    },
    {
      "type": "rect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "y": {"value": -0.02},
          "y2": {"value": -2},
          "width": {"signal": "width"},
          "depth": {"signal": "depth"},
          "fill": {"value": "white"}
        }
      }
    },
    {
      "type": "rect",
      "geometry": "xzrect",
      "encode": {
        "enter": {
          "xc": {"signal": "width/2"},
          "zc": {"signal": "depth/2"},
          "yc": {"value": -2.01},
          "width": {"signal": "width*4"},
          "depth": {"signal": "depth*18"},
          "fill": {"value": "darkgray"}
        }
      }
    },
    {
      "type": "rect",
      "geometry": "boxsdf",
      "material": "metal",
      "from": {"data": "unitstack"},
      "encode": {
        "enter": {
          "x": {"field": "x0", "offset": {"scale": "hour", "field": "hour"}},
          "x2": {"field": "x1", "offset": {"scale": "hour", "field": "hour"}},
          "y": {"field": "y0"},
          "y2": {"field": "y1"},
          "z": {"field": "z0", "offset": {"scale": "strength", "field": "mag"}},
          "z2": {"field": "z1", "offset": {"scale": "strength", "field": "mag"}},
          "rounding": {"value": 0.1},
          "fill": {"scale": "fill", "field": "mag"},
          "fuzz": {"field": "fuzz"}
        }
      }
    }
  ]
}